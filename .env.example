# =====================================================================
# EKBALLO ACADEMY · Configuração de ambiente
# Copie este arquivo para .env.local e preencha conforme o cenário.
# =====================================================================

# -------- MODO DEMONSTRAÇÃO (recomendado para começar) --------
# Quando MOCK_MODE=true, a plataforma roda com dados de teste em memória.
# Ideal para você navegar e testar sem precisar configurar Supabase.
# Deixe true para o primeiro teste local.
NEXT_PUBLIC_MOCK_MODE=true

# -------- MODO PRODUÇÃO (Supabase real) --------
# Quando estiver pronto para usar de verdade, troque MOCK_MODE para false
# e preencha as 3 variáveis abaixo com os dados do seu projeto Supabase.
# Pegue em: supabase.com → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...sua-chave-anon-publica

# URL onde a aplicação está rodando.
# Em desenvolvimento: http://localhost:3000
# Em produção na Vercel: troque pelo seu domínio definitivo
NEXT_PUBLIC_SITE_URL=http://localhost:3000
