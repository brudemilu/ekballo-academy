# Copie este arquivo para .env.local e preencha com os valores do seu projeto Supabase
# (https://supabase.com → seu projeto → Settings → API)

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...sua-chave-anon-publica

# URL onde a aplicação está rodando (em desenvolvimento, http://localhost:3000)
# Em produção na Vercel, troque pelo seu domínio
NEXT_PUBLIC_SITE_URL=http://localhost:3000
