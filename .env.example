# =====================================================================
# EKBALLO ACADEMY · Configuração de ambiente
# Copie este arquivo para .env.local e preencha conforme o cenário.
# =====================================================================

# -------- MODO DEMONSTRAÇÃO (recomendado para começar) --------
# Quando MOCK_MODE=true, a plataforma roda com dados de teste em memória.
# Ideal para você navegar e testar sem precisar configurar Supabase.
# Deixe true para o primeiro teste local.
NEXT_PUBLIC_MOCK_MODE=true

# -------- MODO PRODUÇÃO (Supabase real) --------
# Quando estiver pronto para usar de verdade, troque MOCK_MODE para false
# e preencha as 3 variáveis abaixo com os dados do seu projeto Supabase.
# Pegue em: supabase.com → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...sua-chave-anon-publica

# URL onde a aplicação está rodando.
# Em desenvolvimento: http://localhost:3000
# Em produção na Vercel: troque pelo seu domínio definitivo
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -------- GERADOR DE IMAGEM CINEMATOGRÁFICA --------
# Backend de geração de fundo do template Cinematográfico.
#
#   pollinations (default) → 100% grátis, sem chave, sem limite (Flux Schnell
#                            via image.pollinations.ai). Funciona out-of-the-box.
#   gemini                 → Google Imagen 4 (qualidade fotográfica top mas
#                            exige BILLING ATIVO no AI Studio — o free tier de
#                            imagem está zerado em 2026).
IMAGE_BACKEND=pollinations

# Só preencha se IMAGE_BACKEND=gemini. Chave em https://aistudio.google.com/apikey
# (também precisa habilitar billing em ai.dev/projects pra usar Imagen).
# GEMINI_API_KEY=
# GEMINI_IMAGE_MODEL=imagen-4.0-generate-001

# -------- DOWNLOAD DE ÁUDIO DO YOUTUBE (admin) --------
# Usa uma API de terceiros (RapidAPI) que faz o download e converte em MP3,
# driblando o bloqueio do YouTube. Funciona em produção (Vercel).
#
# Como obter a chave grátis:
#   1. Crie conta em https://rapidapi.com (pode logar com Google)
#   2. Assine (free/Basic, $0) a API "YouTube MP3" — ex: youtube-mp36 (ytjar):
#      https://rapidapi.com/ytjar/api/youtube-mp36
#   3. Copie o valor de "X-RapidAPI-Key" e cole abaixo
YOUTUBE_MP3_API_KEY=

# Host da API. Default = youtube-mp36 (ytjar). Só troque se assinar outra.
YOUTUBE_MP3_API_HOST=youtube-mp36.p.rapidapi.com
